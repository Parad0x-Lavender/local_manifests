<?xml version="1.0" encoding="UTF-8"?>
<manifest>

    <!--Remotes-->
    <remote name="org"          fetch="https://github.com/Parad0x-Lavender"         revision="lineage-20"/>
    <remote name="los"          fetch="https://github.com/LineageOS"                revision="lineage-20"/>

    <!-- Remove Source Settings App -->
    <remove-project name="LineageOS/android_packages_apps_Settings" />

    <!-- Add Own forked Settings App -->
    <project name="android_packages_apps_Settings"      path="packages/apps/Settings"               remote="org"/>
    
    <!--Devices Trees-->
    <project name="device_xiaomi_lavender"              path="device/xiaomi/lavender"               remote="org"/>

    <!--Vendor Trees-->
    <project name="vendor_xiaomi_lavender"              path="vendor/xiaomi/lavender"               remote="org"/>

    <!--Kernel tree-->
    <project name="kernel_xiaomi_lavender"              path="kernel/xiaomi/lavender"               remote="org"/>
    
    <!-- Hardware dependencies -->
    <project name="android_hardware_xiaomi"             path="hardware/xiaomi"                      remote="los"/>

</manifest>
