<?xml version="1.0" encoding="UTF-8"?>
<manifest>

    <!--Remotes-->
    <remote name="org"          fetch="https://github.com/Parad0x-Lavender"         revision="arrow-12.1"/>
    <remote name="Arrow"        fetch="https://github.com/ArrowOS-Devices"          revision="arrow-12.1"/>

    <!--Devices Trees-->
    <project name="android_device_xiaomi_lavender"              path="device/xiaomi/lavender"             remote="org"/>
    <project name="android_device_xiaomi_sdm660-common"         path="device/xiaomi/sdm660-common"        remote="org"/>

    <!--Vendor Trees-->
    <project name="android_vendor_xiaomi_lavender"              path="vendor/xiaomi/lavender"             remote="org"/>
    <project name="android_vendor_xiaomi_sdm660-common"         path="vendor/xiaomi/sdm660-common"        remote="org"/>
    
    <!--Kernel tree-->
    <project name="android_kernel_xiaomi_sdm660_419"            path="kernel/xiaomi/sdm660"               remote="org"/>
    
    <!-- Hardware dependencies -->
    <project name="android_hardware_xiaomi"                     path="hardware/xiaomi"                    remote="Arrow"/>

</manifest>
